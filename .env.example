# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# 各 Agent 模型档位（留空则用 OPENROUTER_MODEL）
# 建议：分诊/安全/K6 用便宜模型，治疗师用质量好的模型
MODEL_TRIAGE=
MODEL_SAFETY=
MODEL_K6=
MODEL_THERAPIST=

# WhatsApp (neonize)
WHATSAPP_DB=whatsapp_session.sqlite3

# 风险评分系数
RISK_ALPHA=0.6
RISK_BETA=0.25
RISK_GAMMA=0.3
RISK_DELTA=0.15

# 会话限制
MAX_TURNS=30
